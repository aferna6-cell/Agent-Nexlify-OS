{
  "name": "agent-os",
  "version": "0.1.0",
  "private": true,
  "description": "Agent OS — the orchestrator + worker-agent library for AgentNexLiFy. A standalone, demoable build of the v1 agent library.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "demo": "tsx cli/demo.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "ci": "npm run typecheck && npm run test"
  },
  "bin": {
    "agent-os": "cli/demo.ts"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
