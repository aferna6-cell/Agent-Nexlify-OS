# Database. Standalone build uses SQLite (no server needed).
# Production swaps this to a Neon/Postgres URL and the datasource provider to "postgresql".
DATABASE_URL="file:./dev.db"

# NextAuth / Auth.js
AUTH_SECRET="dev-secret-change-me"
NEXTAUTH_URL="http://localhost:3000"

# Email magic links. Leave SMTP unset for the demo — the magic link is printed
# to the server console instead of emailed.
EMAIL_FROM="Agent OS <login@agent-os.local>"
# EMAIL_SERVER="smtp://user:pass@smtp.host:587"

# Demo convenience: allow API calls to resolve the seeded demo owner without a
# logged-in session. Off in production.
AUTH_DEMO_BYPASS="true"
DEMO_OWNER_EMAIL="maya@sunsetauto.com"

# Anthropic. Routing uses Haiku, drafts use Sonnet. When unset, agents that need
# the model degrade gracefully (Phase 0's Generalist is hard-coded and needs none).
# ANTHROPIC_API_KEY="sk-ant-..."
ANTHROPIC_MODEL_ROUTING="claude-haiku-4-5-20251001"
ANTHROPIC_MODEL_DRAFT="claude-sonnet-4-6"
