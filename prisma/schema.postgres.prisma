// Agent OS data layer — POSTGRES variant (production).
//
// This file is IDENTICAL to prisma/schema.prisma except the datasource
// `provider` is "postgresql". Prisma 6 cannot select the provider via env(),
// so the production datasource lives in its own schema file. Keep the two in
// sync: prisma/schema.sync.test.ts asserts they differ ONLY by the provider
// line (CI fails otherwise). Generate/migrate against it with:
//   prisma db push   --schema prisma/schema.postgres.prisma
//   prisma generate  --schema prisma/schema.postgres.prisma

generator client {
  provider      = "prisma-client-js"
  // native for local dev; rhel-openssl-3.0.x for the Vercel (Amazon Linux) runtime.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Auth (NextAuth / Auth.js with the Prisma adapter + email magic links)
// ---------------------------------------------------------------------------

model User {
  id            String           @id @default(cuid())
  email         String           @unique
  name          String?
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  profile       BusinessProfile?
  agentRuns     AgentRun[]
  // Set when the owner expresses interest in the AI Visibility beta (Phase 4 stub).
  aiVisibilityInterest Boolean    @default(false)
  createdAt     DateTime         @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------------------------------------------------------------------------
// Shared context / data layer
// ---------------------------------------------------------------------------

model BusinessProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessName String?
  ownerName    String?
  industry     String?
  // v2 (Direction v2 Decision 3): 2-step industry picker. `industryCluster` is
  // one of the 8 clusters (loads the vertical pack); `businessType` is the
  // specific type within it (tunes copy + example asks). `industry` stays for
  // back-compat / free-text.
  industryCluster String?
  businessType    String?
  city         String?
  state        String?
  phone        String?
  email        String?
  website      String?
  hoursSummary String?
  timezone     String?
  reviewLinkGoogle   String?
  reviewLinkYelp     String?
  reviewLinkFacebook String?
  paymentLink        String?
  updatedAt    DateTime @updatedAt
}

model WidgetConversation {
  id          String   @id @default(cuid())
  userId      String
  contactName String?
  intent      String?
  summary     String
  topics      String? // comma-separated
  closedAt    DateTime @default(now())
}

model PipelineLead {
  id              String   @id @default(cuid())
  userId          String
  name            String
  status          String // new | contacted | quoted | booked | won | lost | stale
  subject         String?
  quoteAmount     Float?
  lastContactDate DateTime?
  createdAt       DateTime @default(now())
}

model Appointment {
  id             String   @id @default(cuid())
  userId         String
  customerName   String
  service        String?
  scheduledFor   DateTime
  status         String // scheduled | completed | no_show | cancelled
  reviewRequested Boolean @default(false)
  createdAt      DateTime @default(now())
}

model Invoice {
  id           String   @id @default(cuid())
  userId       String
  customerName String
  number       String
  amount       Float
  issuedAt     DateTime
  dueAt        DateTime
  status       String // paid | unpaid | overdue
  createdAt    DateTime @default(now())
}

// ---------------------------------------------------------------------------
// Agent runs, traces, drafts
// ---------------------------------------------------------------------------

model AgentRun {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  agentId   String
  ownerAsk  String
  params    String? // JSON-encoded extracted params
  status    String      @default("running") // running | completed | failed | no_draft
  createdAt DateTime    @default(now())
  steps     TraceStep[]
  draft     Draft?
  modelCalls ModelCallLog[]
}

model TraceStep {
  id           String   @id @default(cuid())
  runId        String
  run          AgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  ordinal      Int      @default(0)
  step         String
  // completed | skipped_no_data | fallback | work
  status       String
  description  String
  dataSnapshot String? // JSON-encoded evidence for a completed load
  createdAt    DateTime @default(now())
}

model Draft {
  id               String   @id @default(cuid())
  runId            String   @unique
  run              AgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  agentId          String
  channel          String
  title            String
  body             String
  metadata         String? // JSON-encoded
  requiresApproval Boolean  @default(true)
  status           String   @default("pending") // pending | approved | rejected
  createdAt        DateTime @default(now())
}

model WishlistItem {
  id               String   @id @default(cuid())
  userId           String
  request          String
  vertical         String?
  consideredAgents String? // comma-separated
  count            Int      @default(1)
  firstSeen        DateTime @default(now())
  lastSeen         DateTime @default(now())
}

// ---------------------------------------------------------------------------
// Cost tracking — every model call is logged so credit exhaustion is never silent
// ---------------------------------------------------------------------------

model ModelCallLog {
  id           String    @id @default(cuid())
  runId        String?
  run          AgentRun? @relation(fields: [runId], references: [id], onDelete: SetNull)
  purpose      String // routing | draft | other
  model        String
  inputTokens  Int       @default(0)
  outputTokens Int       @default(0)
  costUsd      Float     @default(0)
  ok           Boolean   @default(true)
  error        String?
  createdAt    DateTime  @default(now())
}

// ---------------------------------------------------------------------------
// Routing decisions — logged for every owner ask. This is the dataset we use to
// fine-tune the classifier later (input → chosen agent → confidence → accepted).
// ---------------------------------------------------------------------------

model RoutingDecision {
  id          String   @id @default(cuid())
  userId      String
  runId       String?
  ask         String
  classifier  String // haiku | heuristic
  // routed | ambiguous | wishlist_fallback | owner_override
  decision    String
  chosenAgent String
  confidence  Float    @default(0)
  alternates  String? // JSON [{agent_id, confidence}]
  // true unless the owner re-routed away from this choice
  accepted    Boolean  @default(true)
  changedTo   String?
  createdAt   DateTime @default(now())
}
